{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/index.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/index.js" },
    { "source": "/admin(.*)", "destination": "/index.html" },
    { "source": "/catalog(.*)", "destination": "/index.html" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
