{
  "name": "websapi-root",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "pg": "^8.11.3",
    "dotenv": "^16.4.7",
    "concurrently": "^8.2.2"
